---
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import Link from "@components/Link.astro";
import { SITE, HOME, SOCIALS } from "@consts";
---
<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      
      <!-- Terminal-style intro -->
      <section class="terminal-intro font-mono text-sm text-neutral-500 dark:text-neutral-500">
        <div class="terminal-line" style="--delay: 0">
          <span class="ape-green">&gt;</span>
          <span class="typing-text"> initializing...</span>
          <span class="cursor">▋</span>
        </div>
        <div class="terminal-line" style="--delay: 1">
          <span class="ape-green">&gt;</span>
          <span class="typing-text"> loading profile: shane.sarin</span>
          <span class="cursor">▋</span>
        </div>
        <div class="terminal-line" style="--delay: 2">
          <span class="ape-green">&gt;</span>
          <span class="typing-text"> status: </span>
          <span class="status-ready ape-green">ready</span>
          <span class="cursor final">▋</span>
        </div>
      </section>

      <style>
        .ticker-wrapper {
          overflow: hidden;
          width: 100%;
        }
        .ticker-track {
          display: flex;
          gap: 1.5rem;
          animation: ticker-scroll 25s linear infinite;
          width: max-content;
        }
        .ticker-track:hover {
          animation-play-state: paused;
        }
        @keyframes ticker-scroll {
          0% { transform: translateX(0); }
          100% { transform: translateX(-50%); }
        }
        .ticker-item {
          display: flex;
          align-items: center;
          gap: 0.25rem;
          white-space: nowrap;
          font-size: 11px;
        }
        .ticker-icon {
          width: 12px !important;
          height: 12px !important;
          max-width: 12px !important;
          max-height: 12px !important;
          border-radius: 50%;
          flex-shrink: 0;
        }
        .ticker-symbol {
          font-weight: 600;
          color: #171717;
        }
        :global(.dark) .ticker-symbol {
          color: #fafafa;
        }
        .ticker-price {
          color: #525252;
        }
        :global(.dark) .ticker-price {
          color: #a3a3a3;
        }
        .ticker-change {
          display: flex;
          align-items: center;
          gap: 2px;
        }
        .ticker-up { color: #22c55e; }
        .ticker-down { color: #ef4444; }
      </style>

      <script is:inline>
        async function fetchPrices() {
          try {
            const res = await fetch('https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&order=market_cap_desc&per_page=20&page=1&sparkline=false&price_change_percentage=24h');
            const coins = await res.json();
            
            const formatPrice = function(price) { 
              if (price >= 1000) return '$' + price.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
              if (price >= 1) return '$' + price.toFixed(2);
              return '$' + price.toFixed(4);
            };
            
            let html = '';
            coins.forEach(function(coin) {
              const change = coin.price_change_percentage_24h;
              const isUp = change >= 0;
              const arrow = isUp ? '▲' : '▼';
              const changeClass = isUp ? 'ticker-up' : 'ticker-down';
              const changeText = Math.abs(change).toFixed(2) + '%';
              
              html += '<div class="ticker-item">';
              html += '<img src="' + coin.image + '" alt="' + coin.symbol + '" class="ticker-icon" style="width:12px;height:12px;max-width:12px;" />';
              html += '<span class="ticker-symbol">' + coin.symbol.toUpperCase() + '</span>';
              html += '<span class="ticker-price">' + formatPrice(coin.current_price) + '</span>';
              html += '<span class="ticker-change ' + changeClass + '">' + arrow + ' ' + changeText + '</span>';
              html += '</div>';
            });
            
            // Duplicate for seamless loop
            const tickerContent = document.getElementById('ticker-content');
            if (tickerContent) {
              tickerContent.innerHTML = html + html;
            }
          } catch (e) {
            console.log('Price fetch failed:', e);
            // Don't clear existing content on error
          }
        }
        
        // Prevent any other scripts from modifying ticker
        window.tickerInitialized = true;
        
        var tickerLoaded = false;
        
        function initTicker() {
          if (tickerLoaded) return;
          tickerLoaded = true;
          
          setTimeout(function() {
            var ticker = document.getElementById('price-ticker');
            if (ticker) ticker.style.opacity = '1';
            fetchPrices();
            // Refresh every 2 minutes
            setInterval(fetchPrices, 120000);
          }, 2500);
        }
        
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initTicker);
        } else {
          initTicker();
        }
      </script>

      <style>
        .ape-green {
          color: #2EE59D;
        }
        
        .terminal-intro .terminal-line {
          opacity: 0;
          animation: lineAppear 0.1s ease forwards;
          animation-delay: calc(var(--delay) * 0.8s);
          margin-bottom: 0.25rem;
        }
        
        .terminal-intro .typing-text {
          display: inline-block;
          overflow: hidden;
          white-space: nowrap;
          max-width: 0;
          animation: typeText 0.6s steps(25) forwards;
          animation-delay: calc(var(--delay) * 0.8s + 0.1s);
        }
        
        .terminal-intro .status-ready {
          opacity: 0;
          animation: blinkIn 0.3s ease forwards;
          animation-delay: 2.5s;
        }
        
        .terminal-intro .cursor {
          animation: cursorBlink 0.7s step-end 3, cursorHide 0.1s ease 2.1s forwards;
          animation-delay: calc(var(--delay) * 0.8s);
          margin-left: 1px;
          color: #2EE59D;
        }
        
        .terminal-intro .cursor:not(.final) {
          animation: cursorBlink 0.7s step-end 2, cursorHide 0.1s ease 1.4s forwards;
        }
        
        .terminal-intro .cursor.final {
          animation: cursorBlink 0.7s step-end 4, cursorHide 0.1s ease 4.5s forwards;
          animation-delay: 2.4s;
        }
        
        @keyframes lineAppear {
          to { opacity: 1; }
        }
        
        @keyframes typeText {
          to { max-width: 300px; }
        }
        
        @keyframes blinkIn {
          0% { opacity: 0; }
          50% { opacity: 0; }
          100% { opacity: 1; }
        }
        
        @keyframes cursorBlink {
          0%, 100% { opacity: 1; }
          50% { opacity: 0; }
        }
        
        @keyframes cursorHide {
          to { opacity: 0; }
        }
        
        .page-content {
          opacity: 0;
          transform: translateY(10px);
          animation: contentReveal 0.6s ease forwards;
          animation-delay: 2s;
        }
        
        @keyframes contentReveal {
          to {
            opacity: 1;
            transform: translateY(0);
          }
        }
        
        .ticker-section {
          transition: opacity 0.5s ease;
        }
      </style>

      <!-- Live Price Ticker (outside page-content to avoid opacity conflict) -->
      <section id="price-ticker" class="ticker-section overflow-hidden border-y border-neutral-200 dark:border-neutral-800 py-1 -mx-4 px-4 bg-neutral-50 dark:bg-neutral-900/50" style="opacity: 0; transition: opacity 0.5s ease;">
        <div class="ticker-wrapper">
          <div id="ticker-content" class="ticker-track">
            <span class="text-neutral-500 text-sm">Loading prices...</span>
          </div>
        </div>
      </section>

      <!-- All content wrapper -->
      <div class="page-content space-y-10">

      <!-- Hero Section -->
      <section class="space-y-6">
        <div class="flex items-start gap-6">
          <img 
            src="/profile.jpg" 
            alt="Shane" 
            class="w-24 h-24 rounded-2xl ring-2 ring-neutral-200 dark:ring-neutral-700"
          />
          <div class="space-y-2">
            <h1 class="text-3xl md:text-4xl font-bold text-black dark:text-white tracking-tight">
              Shane Sarin
            </h1>
            <p class="font-mono text-sm text-neutral-500 dark:text-neutral-400">
              builder · collector · explorer
            </p>
          </div>
        </div>
      </section>

      <!-- Thesis Statement -->
      <section class="border-l-2 border-cyan-500 dark:border-cyan-400 pl-6 py-2">
        <p class="text-xl md:text-2xl font-semibold text-black dark:text-white leading-relaxed">
          Building at the intersection of <span class="ape-green">crypto</span>, <span class="text-violet-600 dark:text-violet-400">AI</span>, and <span class="text-amber-600 dark:text-amber-400">culture</span>.
        </p>
      </section>

      <!-- Background -->
      <section class="space-y-6">
        <div class="flex items-center gap-3">
          <span class="font-mono text-xs text-neutral-400 dark:text-neutral-500">01</span>
          <h2 class="font-bold text-black dark:text-white tracking-tight">BACKGROUND</h2>
          <div class="h-px flex-1 bg-neutral-200 dark:bg-neutral-800"></div>
        </div>
        <p class="text-neutral-700 dark:text-neutral-300 leading-relaxed">
          Former Web3 professional with experience at <span class="font-semibold text-black dark:text-white">Consensys</span> and <span class="font-semibold text-black dark:text-white">RECUR</span>—helped scale products, navigated market cycles, and curated my art collection, <Link href="https://2667.io/collection" external underline={false} class="ape-green hover:underline">2667</Link>. UNC Chapel Hill alum 🐏
        </p>
      </section>

      <!-- What I Believe -->
      <section class="space-y-6">
        <div class="flex items-center gap-3">
          <span class="font-mono text-xs text-neutral-400 dark:text-neutral-500">02</span>
          <h2 class="font-bold text-black dark:text-white tracking-tight">WHAT I BELIEVE</h2>
          <div class="h-px flex-1 bg-neutral-200 dark:bg-neutral-800"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="p-4 rounded-xl bg-neutral-50 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800">
            <p class="font-mono text-xs text-cyan-600 dark:text-cyan-400 mb-2">// on crypto</p>
            <p class="text-sm text-neutral-700 dark:text-neutral-300">The best crypto products don't feel like crypto. They just work better.</p>
          </div>
          <div class="p-4 rounded-xl bg-neutral-50 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800">
            <p class="font-mono text-xs text-violet-600 dark:text-violet-400 mb-2">// on AI</p>
            <p class="text-sm text-neutral-700 dark:text-neutral-300">AI amplifies human capability. The winners will be those who learn to collaborate with it.</p>
          </div>
          <div class="p-4 rounded-xl bg-neutral-50 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800">
            <p class="font-mono text-xs text-amber-600 dark:text-amber-400 mb-2">// on culture</p>
            <p class="text-sm text-neutral-700 dark:text-neutral-300">Collecting is curation. What you collect signals what you believe in.</p>
          </div>
          <div class="p-4 rounded-xl bg-neutral-50 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800">
            <p class="font-mono text-xs text-green-600 dark:text-green-400 mb-2">// on building</p>
            <p class="text-sm text-neutral-700 dark:text-neutral-300">Ship fast, learn faster. The best ideas come from doing, not planning.</p>
          </div>
        </div>
      </section>

      <!-- Current Focus -->
      <section class="space-y-6">
        <div class="flex items-center gap-3">
          <span class="font-mono text-xs text-neutral-400 dark:text-neutral-500">03</span>
          <h2 class="font-bold text-black dark:text-white tracking-tight">CURRENT FOCUS</h2>
          <div class="h-px flex-1 bg-neutral-200 dark:bg-neutral-800"></div>
        </div>
        <div class="font-mono text-sm space-y-2">
          <p class="text-neutral-600 dark:text-neutral-400">
            <span class="ape-green">→</span> Exploring the next chapter
          </p>
          <p class="text-neutral-600 dark:text-neutral-400">
            <span class="ape-green">→</span> Building <Link href="/projects" class="ape-green hover:underline">ideas</Link> across AI, infra, and consumer
          </p>
          <p class="text-neutral-600 dark:text-neutral-400">
            <span class="ape-green">→</span> Curating the <Link href="https://2667.io/collection" external class="ape-green hover:underline">2667 collection</Link>
          </p>
        </div>
      </section>

      <!-- Connect -->
      <section class="space-y-6">
        <div class="flex items-center gap-3">
          <span class="font-mono text-xs text-neutral-400 dark:text-neutral-500">04</span>
          <h2 class="font-bold text-black dark:text-white tracking-tight">CONNECT</h2>
          <div class="h-px flex-1 bg-neutral-200 dark:bg-neutral-800"></div>
        </div>
        <div class="flex flex-wrap gap-3">
          {SOCIALS.map(SOCIAL => (
            <a 
              href={SOCIAL.HREF} 
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-200 dark:hover:bg-neutral-700 text-sm font-medium text-neutral-700 dark:text-neutral-300 transition-colors"
            >
              {SOCIAL.NAME}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          ))}
          <a 
            href={`mailto:${SITE.EMAIL}`}
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-200 dark:hover:bg-neutral-700 text-sm font-medium text-neutral-700 dark:text-neutral-300 transition-colors"
          >
            {SITE.EMAIL}
          </a>
        </div>
      </section>

      <!-- Footer terminal -->
      <section class="font-mono text-xs text-neutral-400 dark:text-neutral-600 pt-8 border-t border-neutral-200 dark:border-neutral-800">
        <p><span class="ape-green">//</span> end</p>
      </section>

      </div><!-- end page-content -->

    </div>
  </Container>
</PageLayout>
