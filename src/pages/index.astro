---
import { SITE, SOCIALS } from "@consts";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shane Sarin</title>
  <meta name="description" content="Shane Sarin — builder, collector, explorer" />
  <link rel="icon" type="image/png" href="/ape-icon.png" />
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: #000;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      padding: 2rem;
    }
    
    .container {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
    }
    
    .pfp {
      width: 280px;
      height: 280px;
      border-radius: 24px;
      box-shadow: 0 0 60px rgba(46, 229, 157, 0.3);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    
    .pfp:hover {
      transform: scale(1.02);
      box-shadow: 0 0 80px rgba(46, 229, 157, 0.4);
    }
    
    .name {
      font-size: 1.5rem;
      font-weight: 600;
      color: #fff;
      letter-spacing: 0.02em;
    }
    
    .handle {
      font-size: 0.9rem;
      color: #666;
      font-family: 'SF Mono', Monaco, monospace;
    }
    
    .links {
      display: flex;
      gap: 1.25rem;
      margin-top: 0.5rem;
    }
    
    .links a {
      color: #666;
      text-decoration: none;
      font-size: 0.85rem;
      transition: color 0.2s ease;
    }
    
    .links a:hover {
      color: #2EE59D;
    }
    
    .divider {
      color: #333;
    }
    
    @media (max-width: 480px) {
      .pfp {
        width: 220px;
        height: 220px;
      }
      
      .name {
        font-size: 1.25rem;
      }
      
      .links {
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75rem 1rem;
      }
      
      .divider {
        display: none;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <img 
      src="/collection/boredape.png" 
      alt="BAYC #2667" 
      class="pfp"
    />
    <div class="name">Shane Sarin</div>
    <div class="handle">@shanesarin</div>
    <div class="links">
      <a href="https://twitter.com/shanesarin" target="_blank" rel="noopener">Twitter</a>
      <span class="divider">·</span>
      <a href="https://github.com/2shanez" target="_blank" rel="noopener">GitHub</a>
      <span class="divider">·</span>
      <a href="https://linkedin.com/in/shanesarin" target="_blank" rel="noopener">LinkedIn</a>
      <span class="divider">·</span>
      <a href="mailto:shanesarin@gmail.com">Email</a>
    </div>
  </div>
</body>
</html>
