---
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import Link from "@components/Link.astro";
import { SITE, HOME, SOCIALS } from "@consts";
---
<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="flex flex-col sm:flex-row items-start gap-6 mb-10">
      <img 
        src="/profile.jpg" 
        alt="Shane" 
        class="w-28 h-28 rounded-2xl object-cover shadow-lg"
      />
      <div>
        <p class="text-neutral-500 dark:text-neutral-400 mb-1">Hi, I'm</p>
        <h1 class="text-3xl font-bold text-black dark:text-white">
          Shane <span class="text-2xl">👋🏻</span>
        </h1>
        <p class="text-neutral-500 dark:text-neutral-400 mt-2">
          Web3 · Collector · Builder
        </p>
      </div>
    </div>

    <div class="space-y-12">
      <section>
        <p class="text-lg text-neutral-700 dark:text-neutral-300 leading-relaxed">
          Next chapter loading... Former Web3 professional with experience at Consensys and RECUR—helped scale products, navigated market cycles, and curated my art collection, <Link href="/collection">2667</Link>. UNC Chapel Hill alum.
        </p>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl font-semibold text-black dark:text-white">Let's Connect</h2>
        <p class="text-neutral-600 dark:text-neutral-400">
          If you want to get in touch with me about something or just to say hi, reach out on social media or send me an email.
        </p>
        <ul class="flex flex-wrap gap-2">
          {SOCIALS.map(SOCIAL => (
            <li class="flex gap-x-2 text-nowrap">
              <Link href={SOCIAL.HREF} external aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}>{SOCIAL.NAME}</Link>
              {"/"}
            </li>
          ))}
          <li class="line-clamp-1">
            <Link href={`mailto:${SITE.EMAIL}`} aria-label={`Email ${SITE.NAME}`}>{SITE.EMAIL}</Link>
          </li>
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>
