---
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import Link from "@components/Link.astro";
import { SITE, HOME, SOCIALS } from "@consts";
---
<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <!-- Hero Header -->
    <div class="rounded-2xl bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 p-8 mb-12 shadow-sm">
      <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6">
        <img 
          src="/profile.jpg" 
          alt="Shane" 
          class="w-24 h-24 rounded-2xl object-cover shadow-lg"
        />
        <div class="text-center sm:text-left">
          <h1 class="text-3xl sm:text-4xl font-bold text-black dark:text-white">
            Hi, I'm Shane <span class="text-2xl">👋🏻</span>
          </h1>
          <p class="text-neutral-500 dark:text-neutral-400 mt-2">Web3 · Collector · Builder</p>
        </div>
      </div>
    </div>

    <!-- About -->
    <section class="mb-12">
      <div class="rounded-xl bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 p-6 shadow-sm">
        <h2 class="text-xl font-bold text-black dark:text-white mb-3">About</h2>
        <p class="text-neutral-600 dark:text-neutral-300 leading-relaxed">
          Next chapter loading... Former Web3 professional with experience at Consensys and RECUR—helped scale products, navigated market cycles, and curated my art collection, 2667. UNC Chapel Hill alum.
        </p>
      </div>
    </section>

    <!-- Connect -->
    <section>
      <div class="rounded-xl bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 p-6 shadow-sm">
        <h2 class="text-xl font-bold text-black dark:text-white mb-3">Let's Connect</h2>
        <p class="text-neutral-600 dark:text-neutral-300 mb-4">
          If you want to get in touch with me about something or just to say hi, reach out on social media or send me an email.
        </p>
        <ul class="flex flex-wrap gap-2">
          {SOCIALS.map(SOCIAL => (
            <li class="flex gap-x-2 text-nowrap">
              <Link href={SOCIAL.HREF} external aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}>{SOCIAL.NAME}</Link>
              {"/"}
            </li>
          ))}
          <li class="line-clamp-1">
            <Link href={`mailto:${SITE.EMAIL}`} aria-label={`Email ${SITE.NAME}`}>{SITE.EMAIL}</Link>
          </li>
        </ul>
      </div>
    </section>
  </Container>
</PageLayout>
