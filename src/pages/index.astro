---
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import Link from "@components/Link.astro";
import { SITE, HOME, SOCIALS } from "@consts";
---
<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <!-- Hero -->
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-neutral-100 to-neutral-50 dark:from-neutral-800 dark:to-neutral-900 p-8 mb-12">
      <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-bl from-cyan-500/10 to-transparent rounded-full -translate-y-1/2 translate-x-1/2"></div>
      <div class="relative flex flex-col sm:flex-row items-center sm:items-start gap-6">
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-br from-cyan-400 to-teal-500 rounded-2xl blur-lg opacity-50"></div>
          <img 
            src="/profile.jpg" 
            alt="Shane" 
            class="relative w-24 h-24 rounded-2xl object-cover ring-4 ring-white dark:ring-neutral-700 shadow-xl"
          />
        </div>
        <div class="text-center sm:text-left">
          <h1 class="text-3xl sm:text-4xl font-bold text-black dark:text-white">
            Shane Sarin
          </h1>
          <p class="text-lg text-neutral-500 dark:text-neutral-400 mt-1 font-medium">Web3 · Collector · Builder</p>
        </div>
      </div>
    </div>

    <div class="space-y-12">
      <section>
        <p class="text-lg text-neutral-700 dark:text-neutral-300 leading-relaxed">
          Next chapter loading... Former Web3 professional with experience at Consensys and RECUR—helped scale products, navigated market cycles, and curated my art collection, <Link href="/collection">2667</Link>. UNC Chapel Hill alum.
        </p>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl font-semibold text-black dark:text-white">Let's Connect</h2>
        <p class="text-neutral-600 dark:text-neutral-400">
          Reach out on social media or send me an email.
        </p>
        <ul class="flex flex-wrap gap-2">
          {SOCIALS.map(SOCIAL => (
            <li class="flex gap-x-2 text-nowrap">
              <Link href={SOCIAL.HREF} external aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}>{SOCIAL.NAME}</Link>
              {"/"}
            </li>
          ))}
          <li class="line-clamp-1">
            <Link href={`mailto:${SITE.EMAIL}`} aria-label={`Email ${SITE.NAME}`}>{SITE.EMAIL}</Link>
          </li>
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>
