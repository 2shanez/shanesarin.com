---
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import Link from "@components/Link.astro";
---

<PageLayout title="Collection" description="The 2667 Collection - NFTs by Shane Sarin">
  <Container>
    <div class="space-y-12">
      <div class="space-y-4">
        <h1 class="animate text-3xl font-bold text-black dark:text-white">
          The 2667 Collection
        </h1>
        <p class="animate text-lg opacity-80">
          2667 is more than a number—it's the edition of the Bored Ape that became one of the defining pieces in my journey as a collector. I started collecting NFTs to connect with groundbreaking digital artists and be part of a cultural shift in how we create, share, and value art. My collection reflects that journey—featuring work from visionaries like Pak and Beeple alongside a growing list of other creators I believe in. For me, it's never been about flipping or chasing the next big drop; it's about building a collection that tells a story and supports the artists shaping the future of digital creativity.
        </p>
      </div>

      <section class="animate space-y-6">
        <div class="space-y-3">
          <h2 class="text-2xl font-semibold text-black dark:text-white">The Fungible Collection</h2>
          <p class="opacity-70">by Pak</p>
          <p class="text-sm opacity-60">A groundbreaking collection that redefined our understanding of value in digital art. Released via Sotheby's in April 2021, The Fungible challenged collectors to consider what makes something valuable.</p>
          <Link href="https://www.sothebys.com/en/digital-catalogues/the-fungible-collection-by-pak" external>Learn more →</Link>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="group">
            <div class="aspect-square overflow-hidden rounded-lg bg-black">
              <video autoplay loop muted playsinline class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                <source src="/collection/ACube.mp4" type="video/mp4" />
              </video>
            </div>
            <div class="mt-3">
              <h3 class="font-semibold text-black dark:text-white">A Cube</h3>
              <p class="text-sm opacity-70">Pak</p>
              <p class="text-xs opacity-50">#481/5148</p>
            </div>
          </div>

          <div class="group">
            <div class="aspect-square overflow-hidden rounded-lg bg-black">
              <video autoplay loop muted playsinline class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                <source src="/collection/FiveCubes.mp4" type="video/mp4" />
              </video>
            </div>
            <div class="mt-3">
              <h3 class="font-semibold text-black dark:text-white">Five Cubes</h3>
              <p class="text-sm opacity-70">Pak</p>
              <p class="text-xs opacity-50">#424/571</p>
            </div>
          </div>

          <div class="group">
            <div class="aspect-square overflow-hidden rounded-lg bg-black">
              <video autoplay loop muted playsinline class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                <source src="/collection/Ten_Cubes.mp4" type="video/mp4" />
              </video>
            </div>
            <div class="mt-3">
              <h3 class="font-semibold text-black dark:text-white">Ten Cubes</h3>
              <p class="text-sm opacity-70">Pak</p>
              <p class="text-xs opacity-50">#100/247</p>
            </div>
          </div>

          <div class="group">
            <div class="aspect-square overflow-hidden rounded-lg bg-black">
              <video autoplay loop muted playsinline class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                <source src="/collection/Twenty_Cubes.mp4" type="video/mp4" />
              </video>
            </div>
            <div class="mt-3">
              <h3 class="font-semibold text-black dark:text-white">Twenty Cubes</h3>
              <p class="text-sm opacity-70">Pak</p>
              <p class="text-xs opacity-50">#20/120</p>
            </div>
          </div>

          <div class="group">
            <div class="aspect-square overflow-hidden rounded-lg bg-black">
              <video autoplay loop muted playsinline class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                <source src="/collection/Complexity.mp4" type="video/mp4" />
              </video>
            </div>
            <div class="mt-3">
              <h3 class="font-semibold text-black dark:text-white">Complexity</h3>
              <p class="text-sm opacity-70">Pak</p>
              <p class="text-xs opacity-50">#59/100</p>
            </div>
          </div>
        </div>
      </section>

    </div>
  </Container>
</PageLayout>
