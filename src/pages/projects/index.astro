---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { PROJECTS } from "@consts";

const projects = (await getCollection("projects"))
  .filter(project => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Map project slugs to emoji icons, categories and accent colors
const projectMeta: Record<string, { icon: string; category: string; accent: string }> = {
  'moltbot-setup': { icon: '🤖', category: 'AI', accent: '#8B5CF6' },
  'veritas': { icon: '🎓', category: 'Social', accent: '#3B82F6' },
  'civitas': { icon: '🏛️', category: 'GovTech', accent: '#10B981' },
  'prism': { icon: '🔮', category: 'Infrastructure', accent: '#EC4899' },
  'haven': { icon: '🛡️', category: 'Web3', accent: '#F59E0B' },
  'medgraph': { icon: '🏥', category: 'Healthcare', accent: '#EF4444' },
  'carbonos': { icon: '🌱', category: 'Climate', accent: '#22C55E' },
  'sentinel': { icon: '🔒', category: 'Security', accent: '#64748B' },
  'casebrief': { icon: '⚖️', category: 'Legal', accent: '#6366F1' },
  'muse': { icon: '🎨', category: 'Creator', accent: '#F472B6' },
  'aegis': { icon: '🌐', category: 'AI', accent: '#06B6D4' },
};
---

<PageLayout title={PROJECTS.TITLE} description={PROJECTS.DESCRIPTION}>
  <Container>
    <div class="space-y-12">
      
      <!-- Terminal header -->
      <section class="terminal-intro font-mono text-sm text-neutral-500 dark:text-neutral-500">
        <div class="terminal-line" style="--delay: 0">
          <span class="ape-green">&gt;</span>
          <span class="typing-text"> scanning projects...</span>
          <span class="cursor">▋</span>
        </div>
        <div class="terminal-line" style="--delay: 1">
          <span class="ape-green">&gt;</span>
          <span class="typing-text"> found: </span>
          <span class="status-ready ape-green">{projects.length} concepts</span>
          <span class="cursor final">▋</span>
        </div>
        
      </section>

      <!-- All content wrapper -->
      <div class="page-content space-y-12">
      
        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-black dark:text-white tracking-tight">Projects</h1>
          <p class="text-neutral-500 dark:text-neutral-400 mt-2">Ideas, prototypes, and experiments across emerging technology.</p>
        </div>

      <!-- Projects List -->
      <section class="space-y-6">
        {projects.map((project, index) => {
          const meta = projectMeta[project.slug] || { icon: '📁', category: 'Project', accent: '#6B7280' };
          const num = String(index + 1).padStart(2, '0');
          
          return (
            <a 
              href={`/projects/${project.slug}`}
              class="group block"
            >
              <div class="relative overflow-hidden rounded-xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900/50 hover:border-neutral-300 dark:hover:border-neutral-700 transition-all duration-300">
                
                <!-- Hover glow -->
                <div 
                  class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
                  style={`background: radial-gradient(600px circle at 50% 50%, ${meta.accent}10, transparent 40%);`}
                ></div>
                
                <div class="relative p-6 flex items-start gap-6">
                  
                  <!-- Number -->
                  <div class="hidden sm:block font-mono text-3xl font-bold text-neutral-200 dark:text-neutral-800 group-hover:text-neutral-300 dark:group-hover:text-neutral-700 transition-colors">
                    {num}
                  </div>
                  
                  <!-- Emoji -->
                  <div class="text-3xl flex-shrink-0">
                    {meta.icon}
                  </div>
                  
                  <!-- Content -->
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-3 mb-2">
                      <h3 class="text-lg font-semibold text-black dark:text-white group-hover:text-cyan-600 dark:group-hover:text-cyan-400 transition-colors">
                        {project.data.title}
                      </h3>
                      <span 
                        class="inline-flex items-center px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider rounded-md"
                        style={`background: ${meta.accent}20; color: ${meta.accent};`}
                      >
                        {meta.category}
                      </span>
                    </div>
                    <p class="text-sm text-neutral-600 dark:text-neutral-400 line-clamp-2">
                      {project.data.description}
                    </p>
                  </div>
                  
                  <!-- Arrow -->
                  <div class="hidden sm:flex items-center text-neutral-400 group-hover:text-cyan-500 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                  </div>
                  
                </div>
              </div>
            </a>
          );
        })}
      </section>

      <!-- Footer -->
      <section class="font-mono text-xs text-neutral-400 dark:text-neutral-600 pt-8 border-t border-neutral-200 dark:border-neutral-800">
        <p><span class="ape-green">//</span> more ideas loading...</p>
      </section>

      </div><!-- end page-content -->

    </div>
  </Container>
</PageLayout>

<style>
  .ape-green {
    color: #2EE59D;
  }
  
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .terminal-intro .terminal-line {
    opacity: 0;
    animation: lineAppear 0.1s ease forwards;
    animation-delay: calc(var(--delay) * 0.8s);
    margin-bottom: 0.25rem;
  }
  
  .terminal-intro .typing-text {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    max-width: 0;
    animation: typeText 0.6s steps(25) forwards;
    animation-delay: calc(var(--delay) * 0.8s + 0.1s);
  }
  
  .terminal-intro .status-ready {
    opacity: 0;
    animation: blinkIn 0.3s ease forwards;
    animation-delay: 1.7s;
  }
  
  .terminal-intro .cursor {
    animation: cursorBlink 0.7s step-end 3, cursorHide 0.1s ease 2.1s forwards;
    animation-delay: calc(var(--delay) * 0.8s);
    margin-left: 1px;
    color: #2EE59D;
  }
  
  .terminal-intro .cursor:not(.final) {
    animation: cursorBlink 0.7s step-end 2, cursorHide 0.1s ease 1.4s forwards;
  }
  
  .terminal-intro .cursor.final {
    animation: cursorBlink 0.7s step-end 4, cursorHide 0.1s ease 3.5s forwards;
    animation-delay: 1.6s;
  }
  
  @keyframes lineAppear {
    to { opacity: 1; }
  }
  
  @keyframes typeText {
    to { max-width: 300px; }
  }
  
  @keyframes blinkIn {
    0% { opacity: 0; }
    50% { opacity: 0; }
    100% { opacity: 1; }
  }
  
  @keyframes cursorBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  
  @keyframes cursorHide {
    to { opacity: 0; }
  }
  
  .page-content {
    opacity: 0;
    transform: translateY(10px);
    animation: contentReveal 0.6s ease forwards;
    animation-delay: 2s;
  }
  
  @keyframes contentReveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
