---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import ArrowCard from "@components/ArrowCard.astro";
import { WRITING } from "@consts";

const data = (await getCollection("writing"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

type Acc = {
  [year: string]: CollectionEntry<"writing">[];
}

const posts = data.reduce((acc: Acc, post) => {
    const year = post.data.date.getFullYear().toString();
    if (!acc[year]) {
      acc[year] = [];
    }
    acc[year].push(post);
    return acc;
  }, {});

const years = Object.keys(posts).sort((a, b) => parseInt(b) - parseInt(a));
---

<PageLayout title={WRITING.TITLE} description={WRITING.DESCRIPTION}>
  <Container>
    <div class="space-y-8">

      <!-- Terminal header -->
      <section class="terminal-intro font-mono text-sm text-neutral-500 dark:text-neutral-500">
        <div class="terminal-line" style="--delay: 0">
          <span class="ape-green">&gt;</span>
          <span class="typing-text"> scanning writing...</span>
          <span class="cursor">▋</span>
        </div>
        <div class="terminal-line" style="--delay: 1">
          <span class="ape-green">&gt;</span>
          <span class="typing-text"> found: </span>
          <span class="status-ready ape-green">{data.length} entries</span>
          <span class="cursor final">▋</span>
        </div>
      </section>

      <!-- All content wrapper -->
      <div class="page-content space-y-8">

        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-black dark:text-white tracking-tight">Writing</h1>
          <p class="text-neutral-500 dark:text-neutral-400 mt-2">Essays, thoughts, and explorations.</p>
        </div>

        <div class="space-y-4">
          {years.map(year => (
            <section class="space-y-4">
              <div class="font-semibold text-black dark:text-white">
                {year}
              </div>
              <div>
                <ul class="flex flex-col gap-4">
                  {
                    posts[year].map((post) => (
                      <li>
                        <ArrowCard entry={post}/>
                      </li>
                    ))
                  }
                </ul>
              </div>
            </section>
          ))}
        </div>

        <!-- Footer -->
        <section class="font-mono text-xs text-neutral-400 dark:text-neutral-600 pt-8 border-t border-neutral-200 dark:border-neutral-800">
          <p><span class="ape-green">//</span> more thoughts loading...</p>
        </section>

      </div><!-- end page-content -->

    </div>
  </Container>
</PageLayout>

<style>
  .ape-green {
    color: #2EE59D;
  }

  .terminal-intro .terminal-line {
    opacity: 0;
    animation: lineAppear 0.1s ease forwards;
    animation-delay: calc(var(--delay) * 0.8s);
    margin-bottom: 0.25rem;
  }

  .terminal-intro .typing-text {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    max-width: 0;
    animation: typeText 0.6s steps(25) forwards;
    animation-delay: calc(var(--delay) * 0.8s + 0.1s);
  }

  .terminal-intro .status-ready {
    opacity: 0;
    animation: blinkIn 0.3s ease forwards;
    animation-delay: 1.7s;
  }

  .terminal-intro .cursor {
    animation: cursorBlink 0.7s step-end 3, cursorHide 0.1s ease 2.1s forwards;
    animation-delay: calc(var(--delay) * 0.8s);
    margin-left: 1px;
    color: #2EE59D;
  }

  .terminal-intro .cursor:not(.final) {
    animation: cursorBlink 0.7s step-end 2, cursorHide 0.1s ease 1.4s forwards;
  }

  .terminal-intro .cursor.final {
    animation: cursorBlink 0.7s step-end 4, cursorHide 0.1s ease 3.5s forwards;
    animation-delay: 1.6s;
  }

  @keyframes lineAppear {
    to { opacity: 1; }
  }

  @keyframes typeText {
    to { max-width: 300px; }
  }

  @keyframes blinkIn {
    0% { opacity: 0; }
    50% { opacity: 0; }
    100% { opacity: 1; }
  }

  @keyframes cursorBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @keyframes cursorHide {
    to { opacity: 0; }
  }

  .page-content {
    opacity: 0;
    transform: translateY(10px);
    animation: contentReveal 0.6s ease forwards;
    animation-delay: 2s;
  }

  @keyframes contentReveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
