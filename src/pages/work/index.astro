---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { dateRange } from "@lib/utils";
import { WORK } from "@consts";

const collection = (await getCollection("work"))
  .sort((a, b) => new Date(b.data.dateStart).valueOf() - new Date(a.data.dateStart).valueOf());

const work = await Promise.all(
  collection.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  })
);

// Map company slugs to accent colors (light and dark mode)
const companyMeta: Record<string, { light: string; dark: string }> = {
  'consensys': { light: '#65A300', dark: '#B4FF00' },
  'recur': { light: '#0891B2', dark: '#FFFFFF' },
  'infosys': { light: '#2563EB', dark: '#3B82F6' },
};
---

<PageLayout title={WORK.TITLE} description={WORK.DESCRIPTION}>
  <Container>
    <div class="space-y-8">
      
      <!-- Terminal header -->
      <section class="terminal-intro font-mono text-sm text-neutral-500 dark:text-neutral-500">
        <div class="terminal-line" style="--delay: 0">
          <span class="ape-green">&gt;</span>
          <span class="typing-text"> loading career.log...</span>
          <span class="cursor">▋</span>
        </div>
        <div class="terminal-line" style="--delay: 1">
          <span class="ape-green">&gt;</span>
          <span class="typing-text"> entries: </span>
          <span class="status-ready ape-green">{work.length}</span>
          <span class="cursor final">▋</span>
        </div>
      </section>

      <!-- All content wrapper -->
      <div class="page-content space-y-8">
      
        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-black dark:text-white tracking-tight">Work</h1>
          <p class="text-neutral-500 dark:text-neutral-400 mt-2">Where I've been and what I've built.</p>
        </div>

      <!-- Timeline -->
      <section class="relative">
        <!-- Timeline line -->
        <div class="absolute left-[23px] top-0 bottom-0 w-px bg-neutral-200 dark:bg-neutral-800 hidden sm:block"></div>
        
        <div class="space-y-8">
          {work.map((entry, index) => {
            const meta = companyMeta[entry.slug] || { light: '#525252', dark: '#6B7280' };
            const num = String(index + 1).padStart(2, '0');
            
            return (
              <div class="relative flex gap-6" style={`--accent-light: ${meta.light}; --accent-dark: ${meta.dark};`}>
                
                <!-- Timeline dot -->
                <div class="hidden sm:flex flex-shrink-0 w-12 justify-center">
                  <div 
                    class="timeline-dot w-3 h-3 rounded-full ring-4 ring-white dark:ring-neutral-950 z-10"
                  ></div>
                </div>
                
                <!-- Card -->
                <div class="flex-1 group">
                  <div class="relative overflow-hidden rounded-xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900/50 hover:border-neutral-300 dark:hover:border-neutral-700 transition-all duration-300">
                    
                    <!-- Hover glow -->
                    <div 
                      class="work-glow absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
                    ></div>
                    
                    <!-- Top accent line -->
                    <div 
                      class="work-accent-line absolute top-0 left-0 right-0 h-[2px]"
                    ></div>
                    
                    <div class="relative p-6">
                      
                      <!-- Header -->
                      <div class="flex items-start gap-4 mb-4">
                        {entry.data.logo && (
                          <img 
                            src={entry.data.logo} 
                            alt={entry.data.company} 
                            class="w-12 h-12 rounded-lg object-cover flex-shrink-0 border border-neutral-100 dark:border-neutral-800"
                          />
                        )}
                        <div class="flex-1 min-w-0">
                          <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-1">
                            <h3 class="text-lg font-semibold text-black dark:text-white">
                              {entry.data.company}
                            </h3>
                            <span class="font-mono text-xs text-neutral-400 dark:text-neutral-500">
                              {dateRange(entry.data.dateStart, entry.data.dateEnd)}
                            </span>
                          </div>
                          <span 
                            class="work-badge inline-flex items-center px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider rounded-md"
                          >
                            {entry.data.role}
                          </span>
                        </div>
                      </div>
                      
                      <!-- Description -->
                      <div class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed prose prose-sm dark:prose-invert max-w-none">
                        <entry.Content />
                      </div>
                      
                    </div>
                  </div>
                </div>
                
              </div>
            );
          })}
        </div>
      </section>

      <!-- Resume Download -->
      <section class="flex justify-center pt-4">
        <a
          href="/docs/resume.pdf"
          download
          class="resume-btn group inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900/50 hover:border-[#2EE59D] dark:hover:border-[#2EE59D] transition-all duration-300 font-mono text-sm text-neutral-600 dark:text-neutral-400 hover:text-[#2EE59D] dark:hover:text-[#2EE59D]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-y-0.5">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          download resume
        </a>
      </section>

      <!-- Footer -->
      <section class="font-mono text-xs text-neutral-400 dark:text-neutral-600 pt-8 border-t border-neutral-200 dark:border-neutral-800">
        <p><span class="ape-green">//</span> next chapter loading...</p>
      </section>

      </div><!-- end page-content -->

    </div>
  </Container>
</PageLayout>

<style>
  .ape-green {
    color: #2EE59D;
  }
  
  .terminal-intro .terminal-line {
    opacity: 0;
    animation: lineAppear 0.1s ease forwards;
    animation-delay: calc(var(--delay) * 0.8s);
    margin-bottom: 0.25rem;
  }
  
  .terminal-intro .typing-text {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    max-width: 0;
    animation: typeText 0.6s steps(25) forwards;
    animation-delay: calc(var(--delay) * 0.8s + 0.1s);
  }
  
  .terminal-intro .status-ready {
    opacity: 0;
    animation: blinkIn 0.3s ease forwards;
    animation-delay: 1.7s;
  }
  
  .terminal-intro .cursor {
    animation: cursorBlink 0.7s step-end 3, cursorHide 0.1s ease 2.1s forwards;
    animation-delay: calc(var(--delay) * 0.8s);
    margin-left: 1px;
    color: #2EE59D;
  }
  
  .terminal-intro .cursor:not(.final) {
    animation: cursorBlink 0.7s step-end 2, cursorHide 0.1s ease 1.4s forwards;
  }
  
  .terminal-intro .cursor.final {
    animation: cursorBlink 0.7s step-end 4, cursorHide 0.1s ease 3.5s forwards;
    animation-delay: 1.6s;
  }
  
  @keyframes lineAppear {
    to { opacity: 1; }
  }
  
  @keyframes typeText {
    to { max-width: 300px; }
  }
  
  @keyframes blinkIn {
    0% { opacity: 0; }
    50% { opacity: 0; }
    100% { opacity: 1; }
  }
  
  @keyframes cursorBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  
  @keyframes cursorHide {
    to { opacity: 0; }
  }
  
  .page-content {
    opacity: 0;
    transform: translateY(10px);
    animation: contentReveal 0.6s ease forwards;
    animation-delay: 2s;
  }
  
  @keyframes contentReveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* Light mode accent colors */
  .timeline-dot {
    background: var(--accent-light);
  }
  
  .work-glow {
    background: radial-gradient(600px circle at 50% 50%, color-mix(in srgb, var(--accent-light) 3%, transparent), transparent 40%);
  }
  
  .work-accent-line {
    background: linear-gradient(90deg, var(--accent-light), transparent);
  }
  
  .work-badge {
    background: color-mix(in srgb, var(--accent-light) 20%, transparent);
    color: var(--accent-light);
  }
  
  /* Dark mode accent colors */
  :global(.dark) .timeline-dot {
    background: var(--accent-dark);
  }
  
  :global(.dark) .work-glow {
    background: radial-gradient(600px circle at 50% 50%, color-mix(in srgb, var(--accent-dark) 3%, transparent), transparent 40%);
  }
  
  :global(.dark) .work-accent-line {
    background: linear-gradient(90deg, var(--accent-dark), transparent);
  }
  
  :global(.dark) .work-badge {
    background: color-mix(in srgb, var(--accent-dark) 20%, transparent);
    color: var(--accent-dark);
  }
</style>
