---
import Container from "@components/Container.astro";
import { SITE } from "@consts";

const pathname = Astro.url.pathname;
---
<header>
  <Container>
    <div class="flex justify-between items-center py-2">
      <!-- Shane/Home -->
      <a href="/" class="group flex flex-col items-center gap-1.5 text-neutral-400 dark:text-neutral-500 hover:text-black dark:hover:text-white transition-colors duration-300">
        <img src="/ape-icon.png" alt="Ape" class="h-12 md:h-20 w-auto object-contain dark:invert opacity-50 group-hover:opacity-100 transition-opacity duration-300" />
        <span class="text-[10px] font-mono uppercase tracking-[0.15em]">{SITE.NAME}</span>
      </a>
      
      <!-- Nav Items -->
      <nav class="flex items-center gap-6 md:gap-8">
        <!-- Work -->
        <a 
          href="/work" 
          class:list={[
            "group flex flex-col items-center gap-1.5 transition-all duration-300",
            pathname.startsWith("/work") 
              ? "text-[#2EE59D]" 
              : "text-neutral-400 dark:text-neutral-500 hover:text-black dark:hover:text-white"
          ]}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 md:h-14 w-auto stroke-current opacity-50 group-hover:opacity-100 transition-opacity duration-300" viewBox="0 0 64 64" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="6" y="22" width="52" height="34" rx="3" ry="3"></rect>
            <path d="M22 22V16c0-3 2-5 5-5h10c3 0 5 2 5 5v6"></path>
            <rect x="27" y="30" width="10" height="8" rx="1"></rect>
            <line x1="32" y1="30" x2="32" y2="26"></line>
            <line x1="6" y1="38" x2="27" y2="38"></line>
            <line x1="37" y1="38" x2="58" y2="38"></line>
          </svg>
          <span class="text-[10px] font-mono uppercase tracking-[0.15em]">Work</span>
        </a>
        
        <!-- Projects -->
        <a 
          href="/projects" 
          class:list={[
            "group flex flex-col items-center gap-1.5 transition-all duration-300",
            pathname.startsWith("/projects") 
              ? "text-[#2EE59D]" 
              : "text-neutral-400 dark:text-neutral-500 hover:text-black dark:hover:text-white"
          ]}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 md:h-14 w-auto stroke-current opacity-50 group-hover:opacity-100 transition-opacity duration-300" viewBox="0 0 64 64" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M32 6c-11 0-18 8-18 18 0 7 4 12 8 16 2 2 3 4 3 7v3h14v-3c0-3 1-5 3-7 4-4 8-9 8-16 0-10-7-18-18-18z"></path>
            <path d="M26 28c0 0 2 4 6 4s6-4 6-4" stroke-width="1"></path>
            <line x1="32" y1="32" x2="32" y2="22"></line>
            <path d="M28 24l4-4 4 4" stroke-width="1"></path>
            <rect x="25" y="50" width="14" height="4" rx="1"></rect>
            <rect x="25" y="54" width="14" height="4" rx="1"></rect>
            <path d="M28 58v2c0 1 1 2 2 2h4c1 0 2-1 2-2v-2"></path>
          </svg>
          <span class="text-[10px] font-mono uppercase tracking-[0.15em]">Projects</span>
        </a>
        
        <!-- 2667 Collection -->
        <a 
          href="/collection" 
          class:list={[
            "group flex flex-col items-center gap-1.5 transition-all duration-300",
            pathname.startsWith("/collection") 
              ? "text-[#2EE59D]" 
              : "text-neutral-400 dark:text-neutral-500 hover:text-black dark:hover:text-white"
          ]}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 md:h-14 w-auto stroke-current opacity-50 group-hover:opacity-100 transition-opacity duration-300" viewBox="0 0 40 80" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <!-- Ornate trefoil bow -->
            <circle cx="20" cy="12" r="8"></circle>
            <circle cx="12" cy="18" r="5"></circle>
            <circle cx="28" cy="18" r="5"></circle>
            <circle cx="20" cy="12" r="3"></circle>
            <!-- Shaft -->
            <line x1="20" y1="23" x2="20" y2="68"></line>
            <rect x="18" y="26" width="4" height="6" rx="1"></rect>
            <!-- Key teeth -->
            <path d="M20 68 L20 75 L28 75 L28 68"></path>
            <path d="M20 62 L26 62 L26 58 L20 58"></path>
          </svg>
          <span class="text-[10px] font-mono uppercase tracking-[0.15em]">2667</span>
        </a>
      </nav>
      
      <!-- Theme Toggles -->
      <div class="flex items-center gap-0 pl-3 md:pl-4 border-l border-neutral-200 dark:border-neutral-700">
        <button
          id="light-theme-button"
          aria-label="Light theme"
          class="group size-7 flex items-center justify-center rounded-full"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="size-4 stroke-current group-hover:stroke-black group-hover:dark:stroke-white transition-colors duration-300" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
        </button>
        <button
          id="dark-theme-button"
          aria-label="Dark theme"
          class="group size-7 flex items-center justify-center rounded-full"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="size-4 stroke-current group-hover:stroke-black group-hover:dark:stroke-white transition-colors duration-300" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
      </div>
    </div>
  </Container>
</header>
