---
import Container from "@components/Container.astro";
import { SITE } from "@consts";

const pathname = Astro.url.pathname;
---
<header>
  <Container>
    <div class="flex justify-between items-center py-2">
      <!-- Shane/Home -->
      <a 
        href="/" 
        class:list={[
          "group flex flex-col items-center gap-1.5 transition-colors duration-300",
          pathname === "/" 
            ? "text-[#2EE59D]" 
            : "text-neutral-400 dark:text-neutral-500 hover:text-black dark:hover:text-white"
        ]}
      >
        <img 
          src="/images/ape-icon.png" 
          alt="Ape" 
          class:list={[
            "h-8 md:h-20 w-auto object-contain transition-opacity duration-300",
            pathname === "/" 
              ? "opacity-100 [filter:invert(59%)_sepia(52%)_saturate(652%)_hue-rotate(107deg)_brightness(95%)_contrast(92%)]" 
              : "opacity-50 group-hover:opacity-100 dark:[filter:invert(1)_sepia(1)_saturate(50)_hue-rotate(80deg)_brightness(0.7)]"
          ]}
        />
        <span class="text-[10px] font-mono uppercase tracking-[0.15em] dark:text-[#2EE59D] text-center mr-[-0.15em]">{SITE.NAME}</span>
      </a>
      
      <!-- Nav Items -->
      <nav class="flex items-center gap-3 md:gap-8">
        <!-- Work -->
        <a 
          href="/work" 
          class:list={[
            "group flex flex-col items-center gap-1.5 transition-all duration-300",
            pathname.startsWith("/work") 
              ? "text-[#2EE59D]" 
              : "text-neutral-400 dark:text-neutral-500 hover:text-black dark:hover:text-white"
          ]}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 md:h-14 w-auto stroke-current opacity-50 group-hover:opacity-100 dark:stroke-[#2EE59D] transition-opacity duration-300" viewBox="0 0 64 64" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <!-- Modern building/tower icon -->
            <rect x="16" y="12" width="32" height="48" rx="2"></rect>
            <!-- Windows grid -->
            <rect x="22" y="18" width="6" height="6" stroke-width="1"></rect>
            <rect x="36" y="18" width="6" height="6" stroke-width="1"></rect>
            <rect x="22" y="30" width="6" height="6" stroke-width="1"></rect>
            <rect x="36" y="30" width="6" height="6" stroke-width="1"></rect>
            <rect x="22" y="42" width="6" height="6" stroke-width="1"></rect>
            <rect x="36" y="42" width="6" height="6" stroke-width="1"></rect>
            <!-- Entrance -->
            <path d="M28 60 L28 52 Q28 50 32 50 Q36 50 36 52 L36 60"></path>
            <!-- Antenna/spire -->
            <line x1="32" y1="12" x2="32" y2="4"></line>
            <circle cx="32" cy="3" r="1.5" stroke-width="1"></circle>
            <!-- Base details -->
            <line x1="12" y1="60" x2="52" y2="60"></line>
          </svg>
          <span class="text-[10px] font-mono uppercase tracking-[0.15em] dark:text-[#2EE59D] mr-[-0.15em]">Work</span>
        </a>
        
        <!-- Projects -->
        <a 
          href="/projects" 
          class:list={[
            "group flex flex-col items-center gap-1.5 transition-all duration-300",
            pathname.startsWith("/projects") 
              ? "text-[#2EE59D]" 
              : "text-neutral-400 dark:text-neutral-500 hover:text-black dark:hover:text-white"
          ]}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 md:h-14 w-auto stroke-current opacity-50 group-hover:opacity-100 dark:stroke-[#2EE59D] transition-opacity duration-300" viewBox="0 0 64 64" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <!-- AI Neural Network / Brain -->
            <!-- Central node -->
            <circle cx="32" cy="32" r="6"></circle>
            <circle cx="32" cy="32" r="2" stroke-width="1"></circle>
            <!-- Outer nodes -->
            <circle cx="32" cy="10" r="4"></circle>
            <circle cx="32" cy="54" r="4"></circle>
            <circle cx="10" cy="32" r="4"></circle>
            <circle cx="54" cy="32" r="4"></circle>
            <circle cx="16" cy="16" r="3"></circle>
            <circle cx="48" cy="16" r="3"></circle>
            <circle cx="16" cy="48" r="3"></circle>
            <circle cx="48" cy="48" r="3"></circle>
            <!-- Connections -->
            <line x1="32" y1="14" x2="32" y2="26"></line>
            <line x1="32" y1="38" x2="32" y2="50"></line>
            <line x1="14" y1="32" x2="26" y2="32"></line>
            <line x1="38" y1="32" x2="50" y2="32"></line>
            <!-- Diagonal connections -->
            <line x1="18" y1="18" x2="27" y2="27" stroke-width="1"></line>
            <line x1="46" y1="18" x2="37" y2="27" stroke-width="1"></line>
            <line x1="18" y1="46" x2="27" y2="37" stroke-width="1"></line>
            <line x1="46" y1="46" x2="37" y2="37" stroke-width="1"></line>
          </svg>
          <span class="text-[10px] font-mono uppercase tracking-[0.15em] dark:text-[#2EE59D] mr-[-0.15em]">Projects</span>
        </a>
        
        <!-- Writing -->
        <a
          href="/writing"
          class:list={[
            "group flex flex-col items-center gap-1.5 transition-all duration-300",
            pathname.startsWith("/writing")
              ? "text-[#2EE59D]"
              : "text-neutral-400 dark:text-neutral-500 hover:text-black dark:hover:text-white"
          ]}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 md:h-14 w-auto stroke-current opacity-50 group-hover:opacity-100 dark:stroke-[#2EE59D] transition-opacity duration-300" viewBox="0 0 64 64" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <!-- Ornate open book / manuscript -->
            <!-- Book spine -->
            <path d="M32 16 L32 56"></path>
            <!-- Left page -->
            <path d="M32 16 Q24 14 10 12 L10 52 Q24 54 32 56"></path>
            <!-- Right page -->
            <path d="M32 16 Q40 14 54 12 L54 52 Q40 54 32 56"></path>
            <!-- Left page lines -->
            <line x1="16" y1="22" x2="28" y2="24" stroke-width="1"></line>
            <line x1="16" y1="28" x2="28" y2="30" stroke-width="1"></line>
            <line x1="16" y1="34" x2="28" y2="36" stroke-width="1"></line>
            <line x1="16" y1="40" x2="28" y2="42" stroke-width="1"></line>
            <!-- Right page lines -->
            <line x1="36" y1="24" x2="48" y2="22" stroke-width="1"></line>
            <line x1="36" y1="30" x2="48" y2="28" stroke-width="1"></line>
            <line x1="36" y1="36" x2="48" y2="34" stroke-width="1"></line>
            <line x1="36" y1="42" x2="48" y2="40" stroke-width="1"></line>
            <!-- Decorative details -->
            <circle cx="32" cy="12" r="2" stroke-width="1"></circle>
            <line x1="8" y1="10" x2="10" y2="12" stroke-width="1"></line>
            <line x1="56" y1="10" x2="54" y2="12" stroke-width="1"></line>
          </svg>
          <span class="text-[10px] font-mono uppercase tracking-[0.15em] dark:text-[#2EE59D] mr-[-0.15em]">Writing</span>
        </a>

        <!-- 2667 -->
        <a 
          href="https://2667.io" 
          class="group flex flex-col items-center gap-1.5 transition-all duration-300 text-neutral-400 dark:text-neutral-500 hover:text-black dark:hover:text-white"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 md:h-14 w-auto stroke-current opacity-50 group-hover:opacity-100 dark:stroke-[#2EE59D] transition-opacity duration-300" viewBox="0 0 40 80" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <!-- Ornate trefoil bow -->
            <circle cx="20" cy="12" r="8"></circle>
            <circle cx="12" cy="18" r="5"></circle>
            <circle cx="28" cy="18" r="5"></circle>
            <circle cx="20" cy="12" r="3"></circle>
            <!-- Shaft -->
            <line x1="20" y1="23" x2="20" y2="68"></line>
            <rect x="18" y="26" width="4" height="6" rx="1"></rect>
            <!-- Key teeth -->
            <path d="M20 68 L20 75 L28 75 L28 68"></path>
            <path d="M20 62 L26 62 L26 58 L20 58"></path>
          </svg>
          <span class="text-[10px] font-mono uppercase tracking-[0.15em] dark:text-[#2EE59D] mr-[-0.15em]">2667</span>
        </a>
      </nav>

      <!-- Theme Toggles + Login -->
      <div class="flex items-start gap-1 pl-2 md:pl-6 border-l border-neutral-200 dark:border-neutral-700 pt-1">
        <button
          id="light-theme-button"
          aria-label="Light theme"
          class="group flex items-center justify-center"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 md:h-8 w-auto stroke-current opacity-50 group-hover:opacity-100 dark:stroke-[#2EE59D] transition-opacity duration-300" viewBox="0 0 48 48" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <!-- Ornate sun -->
            <circle cx="24" cy="24" r="8"></circle>
            <circle cx="24" cy="24" r="4" stroke-width="1"></circle>
            <!-- Ornate rays -->
            <line x1="24" y1="4" x2="24" y2="12"></line>
            <line x1="24" y1="36" x2="24" y2="44"></line>
            <line x1="4" y1="24" x2="12" y2="24"></line>
            <line x1="36" y1="24" x2="44" y2="24"></line>
            <!-- Diagonal rays -->
            <line x1="9.86" y1="9.86" x2="15.51" y2="15.51"></line>
            <line x1="32.49" y1="32.49" x2="38.14" y2="38.14"></line>
            <line x1="9.86" y1="38.14" x2="15.51" y2="32.49"></line>
            <line x1="32.49" y1="15.51" x2="38.14" y2="9.86"></line>
            <!-- Small decorative dots at ray ends -->
            <circle cx="24" cy="4" r="1.5" stroke-width="1"></circle>
            <circle cx="24" cy="44" r="1.5" stroke-width="1"></circle>
            <circle cx="4" cy="24" r="1.5" stroke-width="1"></circle>
            <circle cx="44" cy="24" r="1.5" stroke-width="1"></circle>
          </svg>
        </button>
        <button
          id="dark-theme-button"
          aria-label="Dark theme"
          class="group flex items-center justify-center"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 md:h-8 w-auto stroke-current opacity-50 group-hover:opacity-100 dark:stroke-[#2EE59D] transition-opacity duration-300" viewBox="0 0 48 48" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <!-- Ornate crescent moon -->
            <path d="M36 24c0 8.84-7.16 16-16 16-2.63 0-5.11-.64-7.3-1.77A16 16 0 0 0 36 24c0-5.05-2.34-9.56-6-12.5A15.9 15.9 0 0 1 36 24z"></path>
            <!-- Stars -->
            <circle cx="38" cy="12" r="1.5" stroke-width="1"></circle>
            <circle cx="42" cy="20" r="1" stroke-width="1"></circle>
            <circle cx="34" cy="8" r="1" stroke-width="1"></circle>
            <!-- Decorative detail on moon -->
            <circle cx="22" cy="18" r="2" stroke-width="1"></circle>
            <circle cx="18" cy="28" r="1.5" stroke-width="1"></circle>
          </svg>
        </button>
        <!-- Login / Dashboard -->
        <a
          id="auth-link"
          href="/login"
          class="group flex items-center justify-center ml-1 text-neutral-400 dark:text-neutral-500 hover:text-black dark:hover:text-white transition-all duration-300"
        >
          <!-- Locked state (logged out) -->
          <svg id="lock-closed" xmlns="http://www.w3.org/2000/svg" class="h-6 md:h-8 w-auto stroke-current opacity-50 group-hover:opacity-100 dark:stroke-[#2EE59D] transition-all duration-500" viewBox="0 0 48 48" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <!-- Lock body with ornate detail -->
            <rect x="10" y="24" width="28" height="20" rx="3"></rect>
            <rect x="14" y="28" width="20" height="12" rx="1.5" stroke-width="0.75" opacity="0.3"></rect>
            <!-- Shackle -->
            <path d="M16 24V16a8 8 0 0 1 16 0v8"></path>
            <!-- Keyhole -->
            <circle cx="24" cy="33" r="3"></circle>
            <path d="M24 36v3"></path>
            <!-- Ornate rivets -->
            <circle cx="14" cy="27" r="1" stroke-width="0.75"></circle>
            <circle cx="34" cy="27" r="1" stroke-width="0.75"></circle>
            <circle cx="14" cy="41" r="1" stroke-width="0.75"></circle>
            <circle cx="34" cy="41" r="1" stroke-width="0.75"></circle>
          </svg>
          <!-- Unlocked state (logged in) -->
          <svg id="lock-open" xmlns="http://www.w3.org/2000/svg" class="h-6 md:h-8 w-auto transition-all duration-500 hidden" viewBox="0 0 48 48" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="stroke: #2EE59D;">
            <!-- Lock body -->
            <rect x="10" y="24" width="28" height="20" rx="3"></rect>
            <rect x="14" y="28" width="20" height="12" rx="1.5" stroke-width="0.75" opacity="0.3"></rect>
            <!-- Shackle (open/lifted) -->
            <path d="M16 24V16a8 8 0 0 1 16 0v2"></path>
            <!-- Keyhole (glowing) -->
            <circle cx="24" cy="33" r="3" style="fill: #2EE59D; opacity: 0.25;"></circle>
            <circle cx="24" cy="33" r="3"></circle>
            <path d="M24 36v3"></path>
            <!-- Ornate rivets -->
            <circle cx="14" cy="27" r="1" stroke-width="0.75"></circle>
            <circle cx="34" cy="27" r="1" stroke-width="0.75"></circle>
            <circle cx="14" cy="41" r="1" stroke-width="0.75"></circle>
            <circle cx="34" cy="41" r="1" stroke-width="0.75"></circle>
          </svg>
        </a>
      </div>
    </div>
  </Container>
</header>

<script>
  function updateLockState() {
    const isLoggedIn = sessionStorage.getItem('dash_auth') === 'true';
    const lockClosed = document.getElementById('lock-closed');
    const lockOpen = document.getElementById('lock-open');
    const authLink = document.getElementById('auth-link') as HTMLAnchorElement | null;

    if (!lockClosed || !lockOpen || !authLink) return;

    if (isLoggedIn) {
      lockClosed.classList.add('hidden');
      lockOpen.classList.remove('hidden');
      authLink.href = '/dashboard';
      authLink.classList.remove('text-neutral-400', 'dark:text-neutral-500');
      authLink.classList.add('text-[#2EE59D]');
    } else {
      lockClosed.classList.remove('hidden');
      lockOpen.classList.add('hidden');
      authLink.href = '/login';
      authLink.classList.add('text-neutral-400', 'dark:text-neutral-500');
      authLink.classList.remove('text-[#2EE59D]');
    }
  }

  updateLockState();
  // Re-check when tab regains focus (e.g. after login in another tab)
  document.addEventListener('visibilitychange', () => {
    if (!document.hidden) updateLockState();
  });
</script>
