---
import Container from "@components/Container.astro";
import { SITE } from "@consts";

const pathname = Astro.url.pathname;
---
<header>
  <Container>
    <div class="flex justify-between items-start py-2">
      <!-- Shane/Home -->
      <a href="/" class="group flex flex-col items-center gap-1.5 text-neutral-400 dark:text-neutral-500 hover:text-black dark:hover:text-white transition-colors duration-300">
        <img src="/ape-icon.png" alt="Ape" class="h-12 md:h-20 w-auto object-contain dark:[filter:invert(1)_sepia(1)_saturate(50)_hue-rotate(80deg)_brightness(0.7)] opacity-50 group-hover:opacity-100 transition-opacity duration-300" />
        <span class="text-[10px] font-mono uppercase tracking-[0.15em] dark:text-[#2EE59D]">{SITE.NAME}</span>
      </a>
      
      <!-- Nav Items -->
      <nav class="flex items-center gap-6 md:gap-8">
        <!-- Work -->
        <a 
          href="/work" 
          class:list={[
            "group flex flex-col items-center gap-1.5 transition-all duration-300",
            pathname.startsWith("/work") 
              ? "text-[#2EE59D]" 
              : "text-neutral-400 dark:text-neutral-500 hover:text-black dark:hover:text-white"
          ]}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 md:h-14 w-auto stroke-current opacity-50 group-hover:opacity-100 dark:stroke-[#2EE59D] transition-opacity duration-300" viewBox="0 0 64 72" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <!-- Ornate vintage briefcase -->
            <!-- Main body with curved top -->
            <path d="M4 28 Q4 24 8 24 L56 24 Q60 24 60 28 L60 62 Q60 66 56 66 L8 66 Q4 66 4 62 Z"></path>
            <!-- Handle -->
            <path d="M24 24 L24 16 Q24 10 32 10 Q40 10 40 16 L40 24"></path>
            <path d="M28 24 L28 18 Q28 14 32 14 Q36 14 36 18 L36 24"></path>
            <!-- Decorative center clasp -->
            <ellipse cx="32" cy="45" rx="8" ry="6"></ellipse>
            <circle cx="32" cy="45" r="3"></circle>
            <!-- Decorative straps -->
            <line x1="4" y1="36" x2="24" y2="36"></line>
            <line x1="40" y1="36" x2="60" y2="36"></line>
            <line x1="4" y1="54" x2="24" y2="54"></line>
            <line x1="40" y1="54" x2="60" y2="54"></line>
            <!-- Corner details -->
            <circle cx="12" cy="30" r="2" stroke-width="1"></circle>
            <circle cx="52" cy="30" r="2" stroke-width="1"></circle>
          </svg>
          <span class="text-[10px] font-mono uppercase tracking-[0.15em] dark:text-[#2EE59D]">Work</span>
        </a>
        
        <!-- Projects -->
        <a 
          href="/projects" 
          class:list={[
            "group flex flex-col items-center gap-1.5 transition-all duration-300",
            pathname.startsWith("/projects") 
              ? "text-[#2EE59D]" 
              : "text-neutral-400 dark:text-neutral-500 hover:text-black dark:hover:text-white"
          ]}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 md:h-14 w-auto stroke-current opacity-50 group-hover:opacity-100 dark:stroke-[#2EE59D] transition-opacity duration-300" viewBox="0 0 64 80" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <!-- Ornate vintage lightbulb -->
            <!-- Bulb glass with elegant curve -->
            <path d="M32 4 Q12 4 12 28 Q12 40 20 48 Q24 52 24 58 L40 58 Q40 52 44 48 Q52 40 52 28 Q52 4 32 4"></path>
            <!-- Inner filament ornate design -->
            <path d="M28 20 Q32 16 36 20" stroke-width="1"></path>
            <path d="M26 28 Q32 22 38 28" stroke-width="1"></path>
            <line x1="32" y1="20" x2="32" y2="36"></line>
            <path d="M28 32 L32 36 L36 32" stroke-width="1"></path>
            <!-- Decorative base/screw cap -->
            <rect x="24" y="58" width="16" height="4" rx="1"></rect>
            <path d="M26 62 L26 66 Q26 68 28 68 L36 68 Q38 68 38 66 L38 62"></path>
            <line x1="24" y1="64" x2="40" y2="64" stroke-width="1"></line>
            <line x1="25" y1="67" x2="39" y2="67" stroke-width="1"></line>
            <!-- Decorative rays -->
            <line x1="6" y1="28" x2="2" y2="28" stroke-width="1"></line>
            <line x1="58" y1="28" x2="62" y2="28" stroke-width="1"></line>
            <line x1="10" y1="12" x2="6" y2="8" stroke-width="1"></line>
            <line x1="54" y1="12" x2="58" y2="8" stroke-width="1"></line>
            <line x1="32" y1="0" x2="32" y2="-4" stroke-width="1"></line>
          </svg>
          <span class="text-[10px] font-mono uppercase tracking-[0.15em] dark:text-[#2EE59D]">Projects</span>
        </a>
        
        <!-- 2667 -->
        <a 
          href="https://2667.io" 
          class="group flex flex-col items-center gap-1.5 transition-all duration-300 text-neutral-400 dark:text-neutral-500 hover:text-black dark:hover:text-white"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 md:h-14 w-auto stroke-current opacity-50 group-hover:opacity-100 dark:stroke-[#2EE59D] transition-opacity duration-300" viewBox="0 0 40 80" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <!-- Ornate trefoil bow -->
            <circle cx="20" cy="12" r="8"></circle>
            <circle cx="12" cy="18" r="5"></circle>
            <circle cx="28" cy="18" r="5"></circle>
            <circle cx="20" cy="12" r="3"></circle>
            <!-- Shaft -->
            <line x1="20" y1="23" x2="20" y2="68"></line>
            <rect x="18" y="26" width="4" height="6" rx="1"></rect>
            <!-- Key teeth -->
            <path d="M20 68 L20 75 L28 75 L28 68"></path>
            <path d="M20 62 L26 62 L26 58 L20 58"></path>
          </svg>
          <span class="text-[10px] font-mono uppercase tracking-[0.15em] dark:text-[#2EE59D]">2667</span>
        </a>
      </nav>
      
      <!-- Theme Toggles -->
      <div class="flex items-center gap-2 pl-4 md:pl-6 border-l border-neutral-200 dark:border-neutral-700">
        <button
          id="light-theme-button"
          aria-label="Light theme"
          class="group flex items-center justify-center"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 md:h-8 w-auto stroke-current opacity-50 group-hover:opacity-100 dark:stroke-[#2EE59D] transition-opacity duration-300" viewBox="0 0 48 48" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <!-- Ornate sun -->
            <circle cx="24" cy="24" r="8"></circle>
            <circle cx="24" cy="24" r="4" stroke-width="1"></circle>
            <!-- Ornate rays -->
            <line x1="24" y1="4" x2="24" y2="12"></line>
            <line x1="24" y1="36" x2="24" y2="44"></line>
            <line x1="4" y1="24" x2="12" y2="24"></line>
            <line x1="36" y1="24" x2="44" y2="24"></line>
            <!-- Diagonal rays -->
            <line x1="9.86" y1="9.86" x2="15.51" y2="15.51"></line>
            <line x1="32.49" y1="32.49" x2="38.14" y2="38.14"></line>
            <line x1="9.86" y1="38.14" x2="15.51" y2="32.49"></line>
            <line x1="32.49" y1="15.51" x2="38.14" y2="9.86"></line>
            <!-- Small decorative dots at ray ends -->
            <circle cx="24" cy="4" r="1.5" stroke-width="1"></circle>
            <circle cx="24" cy="44" r="1.5" stroke-width="1"></circle>
            <circle cx="4" cy="24" r="1.5" stroke-width="1"></circle>
            <circle cx="44" cy="24" r="1.5" stroke-width="1"></circle>
          </svg>
        </button>
        <button
          id="dark-theme-button"
          aria-label="Dark theme"
          class="group flex items-center justify-center"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 md:h-8 w-auto stroke-current opacity-50 group-hover:opacity-100 dark:stroke-[#2EE59D] transition-opacity duration-300" viewBox="0 0 48 48" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <!-- Ornate crescent moon -->
            <path d="M36 24c0 8.84-7.16 16-16 16-2.63 0-5.11-.64-7.3-1.77A16 16 0 0 0 36 24c0-5.05-2.34-9.56-6-12.5A15.9 15.9 0 0 1 36 24z"></path>
            <!-- Stars -->
            <circle cx="38" cy="12" r="1.5" stroke-width="1"></circle>
            <circle cx="42" cy="20" r="1" stroke-width="1"></circle>
            <circle cx="34" cy="8" r="1" stroke-width="1"></circle>
            <!-- Decorative detail on moon -->
            <circle cx="22" cy="18" r="2" stroke-width="1"></circle>
            <circle cx="18" cy="28" r="1.5" stroke-width="1"></circle>
          </svg>
        </button>
      </div>
    </div>
  </Container>
</header>
