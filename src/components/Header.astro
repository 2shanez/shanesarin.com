---
import Container from "@components/Container.astro";
import { SITE } from "@consts";

const pathname = Astro.url.pathname;
---
<header>
  <Container>
    <div class="flex flex-wrap gap-y-4 justify-between items-center py-4">
      <a href="/" class="group flex flex-col items-center gap-2 text-neutral-400 dark:text-neutral-500 hover:text-black dark:hover:text-white transition-colors duration-300">
        <img src="/ape-icon.png" alt="Ape" class="h-14 w-auto object-contain dark:invert opacity-50 group-hover:opacity-100 transition-opacity duration-300" />
        <span class="text-xs font-mono uppercase tracking-[0.2em]">{SITE.NAME}</span>
      </a>
      <div class="flex items-center gap-6">
        <nav class="flex items-center gap-10">
          <!-- Work - Briefcase illustration -->
          <a 
            href="/work" 
            class:list={[
              "group flex flex-col items-center gap-2 transition-all duration-300",
              pathname.startsWith("/work") 
                ? "text-[#2EE59D]" 
                : "text-neutral-400 dark:text-neutral-500 hover:text-black dark:hover:text-white"
            ]}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-auto stroke-current opacity-50 group-hover:opacity-100 transition-opacity duration-300" viewBox="0 0 64 64" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <!-- Briefcase body -->
              <rect x="6" y="22" width="52" height="34" rx="3" ry="3"></rect>
              <!-- Handle -->
              <path d="M22 22V16c0-3 2-5 5-5h10c3 0 5 2 5 5v6"></path>
              <!-- Clasp -->
              <rect x="27" y="30" width="10" height="8" rx="1"></rect>
              <line x1="32" y1="30" x2="32" y2="26"></line>
              <!-- Details -->
              <line x1="6" y1="38" x2="27" y2="38"></line>
              <line x1="37" y1="38" x2="58" y2="38"></line>
              <!-- Stitching details -->
              <path d="M10 26c0 0 1-1 2-1s2 1 2 1" stroke-width="1"></path>
              <path d="M50 26c0 0 1-1 2-1s2 1 2 1" stroke-width="1"></path>
            </svg>
            <span class="text-xs font-mono uppercase tracking-[0.2em]">Work</span>
          </a>
          
          <!-- Projects - Lightbulb/idea illustration -->
          <a 
            href="/projects" 
            class:list={[
              "group flex flex-col items-center gap-2 transition-all duration-300",
              pathname.startsWith("/projects") 
                ? "text-[#2EE59D]" 
                : "text-neutral-400 dark:text-neutral-500 hover:text-black dark:hover:text-white"
            ]}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-auto stroke-current opacity-50 group-hover:opacity-100 transition-opacity duration-300" viewBox="0 0 64 64" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <!-- Bulb glass -->
              <path d="M32 6c-11 0-18 8-18 18 0 7 4 12 8 16 2 2 3 4 3 7v3h14v-3c0-3 1-5 3-7 4-4 8-9 8-16 0-10-7-18-18-18z"></path>
              <!-- Filament -->
              <path d="M26 28c0 0 2 4 6 4s6-4 6-4" stroke-width="1"></path>
              <line x1="32" y1="32" x2="32" y2="22"></line>
              <path d="M28 24l4-4 4 4" stroke-width="1"></path>
              <!-- Base -->
              <rect x="25" y="50" width="14" height="4" rx="1"></rect>
              <rect x="25" y="54" width="14" height="4" rx="1"></rect>
              <path d="M28 58v2c0 1 1 2 2 2h4c1 0 2-1 2-2v-2"></path>
              <!-- Glow lines -->
              <line x1="10" y1="24" x2="6" y2="24" stroke-width="1"></line>
              <line x1="54" y1="24" x2="58" y2="24" stroke-width="1"></line>
              <line x1="14" y1="10" x2="10" y2="6" stroke-width="1"></line>
              <line x1="50" y1="10" x2="54" y2="6" stroke-width="1"></line>
            </svg>
            <span class="text-xs font-mono uppercase tracking-[0.2em]">Projects</span>
          </a>
          
          <!-- 2667 Collection - Ornate key illustration -->
          <a 
            href="/collection" 
            class:list={[
              "group flex flex-col items-center gap-2 transition-all duration-300",
              pathname.startsWith("/collection") 
                ? "text-[#2EE59D]" 
                : "text-neutral-400 dark:text-neutral-500 hover:text-black dark:hover:text-white"
            ]}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-auto stroke-current opacity-50 group-hover:opacity-100 transition-opacity duration-300" viewBox="0 0 64 64" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <!-- Key bow (ornate circular top) -->
              <circle cx="20" cy="20" r="14"></circle>
              <circle cx="20" cy="20" r="8"></circle>
              <!-- Decorative elements on bow -->
              <circle cx="20" cy="10" r="2" stroke-width="1"></circle>
              <circle cx="10" cy="20" r="2" stroke-width="1"></circle>
              <circle cx="30" cy="20" r="2" stroke-width="1"></circle>
              <circle cx="20" cy="30" r="2" stroke-width="1"></circle>
              <!-- Key shaft -->
              <line x1="28" y1="28" x2="56" y2="56"></line>
              <!-- Key teeth -->
              <path d="M48 48l6 0 0 6"></path>
              <path d="M42 42l4 0 0 4"></path>
              <!-- Decorative notch -->
              <path d="M36 36l2-2 2 2" stroke-width="1"></path>
            </svg>
            <span class="text-xs font-mono uppercase tracking-[0.2em]">2667</span>
          </a>
        </nav>
        
        <div class="flex items-center gap-0 pl-6 border-l border-neutral-200 dark:border-neutral-700">
          <button
            id="light-theme-button"
            aria-label="Light theme"
            class="group size-9 flex items-center justify-center rounded-full"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="group-hover:stroke-black group-hover:dark:stroke-white transition-colors duration-300 ease-in-out"
            >
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
          </button>
          <button
            id="dark-theme-button"
            aria-label="Dark theme"
            class="group size-9 flex items-center justify-center rounded-full"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="group-hover:stroke-black group-hover:dark:stroke-white transition-colors duration-300 ease-in-out"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>
          <button
            id="system-theme-button"
            aria-label="System theme"
            class="group size-9 flex items-center justify-center rounded-full"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="group-hover:stroke-black group-hover:dark:stroke-white transition-colors duration-300 ease-in-out"
            >
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
              <line x1="8" y1="21" x2="16" y2="21"></line>
              <line x1="12" y1="17" x2="12" y2="21"></line>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </Container>
</header>
