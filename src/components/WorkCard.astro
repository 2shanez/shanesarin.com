---
import type { CollectionEntry } from "astro:content";
import { dateRange } from "@lib/utils";

type Props = {
  entry: CollectionEntry<"work">;
  Content: any;
}

const { entry, Content } = Astro.props;

// Map company slugs to accent colors (light and dark mode)
const companyMeta: Record<string, { light: string; dark: string }> = {
  'consensys': { light: '#65A300', dark: '#B4FF00' },
  'recur': { light: '#0891B2', dark: '#FFFFFF' },
  'infosys': { light: '#2563EB', dark: '#3B82F6' },
};

const meta = companyMeta[entry.slug] || { light: '#525252', dark: '#6B7280' };
---

<div class="group relative block" style={`--accent-light: ${meta.light}; --accent-dark: ${meta.dark};`}>
  <div class="relative overflow-hidden rounded-xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900/50 backdrop-blur-sm transition-all duration-500 ease-out hover:border-neutral-300 dark:hover:border-neutral-700 hover:shadow-lg dark:hover:shadow-2xl dark:hover:shadow-neutral-900/50">
    
    <!-- Subtle gradient glow on hover -->
    <div 
      class="accent-glow absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
    ></div>
    
    <!-- Top accent line -->
    <div 
      class="accent-line absolute top-0 left-0 right-0 h-[2px] opacity-0 group-hover:opacity-100 transition-opacity duration-500"
    ></div>
    
    <div class="relative p-5">
      <!-- Header: Logo + Company + Role -->
      <div class="flex items-start gap-4 mb-4">
        {entry.data.logo && (
          <img 
            src={entry.data.logo} 
            alt={entry.data.company} 
            class="w-12 h-12 rounded-lg object-cover flex-shrink-0 border border-neutral-100 dark:border-neutral-800"
          />
        )}
        <div class="flex-1 min-w-0">
          <div class="flex items-center justify-between gap-2 mb-1">
            <h3 class="text-base font-semibold text-neutral-900 dark:text-white">
              {entry.data.company}
            </h3>
            <span class="text-xs text-neutral-400 dark:text-neutral-500 font-medium whitespace-nowrap">
              {dateRange(entry.data.dateStart, entry.data.dateEnd)}
            </span>
          </div>
          <span 
            class="accent-badge inline-flex items-center px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider rounded-md"
          >
            {entry.data.role}
          </span>
        </div>
      </div>
      
      <!-- Description -->
      <div class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed prose prose-sm dark:prose-invert max-w-none">
        <Content />
      </div>
    </div>
  </div>
</div>

<style>
  .accent-badge {
    background: color-mix(in srgb, var(--accent-light) 15%, transparent);
    color: var(--accent-light);
  }
  
  .accent-glow {
    background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), color-mix(in srgb, var(--accent-light) 3%, transparent), transparent 40%);
  }
  
  .accent-line {
    background: linear-gradient(90deg, transparent, var(--accent-light), transparent);
  }
  
  :global(.dark) .accent-badge {
    background: color-mix(in srgb, var(--accent-dark) 15%, transparent);
    color: var(--accent-dark);
  }
  
  :global(.dark) .accent-glow {
    background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), color-mix(in srgb, var(--accent-dark) 3%, transparent), transparent 40%);
  }
  
  :global(.dark) .accent-line {
    background: linear-gradient(90deg, transparent, var(--accent-dark), transparent);
  }
</style>
