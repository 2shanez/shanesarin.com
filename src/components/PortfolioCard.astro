---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry: CollectionEntry<"projects">;
}

const { entry } = Astro.props;

// Map project slugs to emoji icons, categories and accent colors
const projectMeta: Record<string, { icon: string; category: string; accent: string }> = {
  'goalstake': { icon: '💪', category: 'Web3', accent: '#10B981' },
  'veritas': { icon: '🎓', category: 'Social', accent: '#3B82F6' },
  'civitas': { icon: '🏛️', category: 'GovTech', accent: '#10B981' },
  'prism': { icon: '🔮', category: 'Infrastructure', accent: '#EC4899' },
  'haven': { icon: '🛡️', category: 'Web3', accent: '#F59E0B' },
  'medgraph': { icon: '🏥', category: 'Healthcare', accent: '#EF4444' },
  'carbonos': { icon: '🌱', category: 'Climate', accent: '#22C55E' },
  'sentinel': { icon: '🔒', category: 'Security', accent: '#64748B' },
  'casebrief': { icon: '⚖️', category: 'Legal', accent: '#6366F1' },
  'muse': { icon: '🎨', category: 'Creator', accent: '#F472B6' },
  'aegis': { icon: '🌐', category: 'AI', accent: '#06B6D4' },
};

const meta = projectMeta[entry.slug] || { icon: '📁', category: 'Project', accent: '#6B7280' };
---

<a 
  href={`/projects/${entry.slug}`} 
  class="group relative block"
>
  <div class="relative overflow-hidden rounded-xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900/50 backdrop-blur-sm transition-all duration-500 ease-out hover:border-neutral-300 dark:hover:border-neutral-700 hover:shadow-lg dark:hover:shadow-2xl dark:hover:shadow-neutral-900/50 h-full">
    
    <!-- Subtle gradient glow on hover -->
    <div 
      class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
      style={`background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), ${meta.accent}08, transparent 40%);`}
    ></div>
    
    <!-- Top accent line -->
    <div 
      class="absolute top-0 left-0 right-0 h-[2px] opacity-0 group-hover:opacity-100 transition-opacity duration-500"
      style={`background: linear-gradient(90deg, transparent, ${meta.accent}, transparent);`}
    ></div>
    
    <div class="relative p-5 flex flex-col h-full">
      <!-- Header: Emoji + Category -->
      <div class="flex items-center justify-between mb-3">
        <div class="flex items-center gap-2">
          <span class="text-2xl">{meta.icon}</span>
          <span 
            class="inline-flex items-center px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider rounded-md"
            style={`background: ${meta.accent}15; color: ${meta.accent};`}
          >
            {meta.category}
          </span>
        </div>
      </div>
      
      <!-- Title -->
      <h3 class="text-base font-semibold text-neutral-900 dark:text-white mb-2 group-hover:text-neutral-700 dark:group-hover:text-neutral-100 transition-colors duration-300">
        {entry.data.title}
      </h3>
      
      <!-- Description -->
      <p class="text-sm text-neutral-600 dark:text-neutral-400 line-clamp-2 leading-relaxed flex-1">
        {entry.data.description}
      </p>
      
      <!-- Footer -->
      <div class="flex items-center justify-between pt-4 mt-4 border-t border-neutral-100 dark:border-neutral-800">
        <span class="text-xs text-neutral-400 dark:text-neutral-500 font-medium">
          {entry.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
        </span>
        <span class="flex items-center gap-1.5 text-xs font-medium text-neutral-500 dark:text-neutral-400 group-hover:text-neutral-900 dark:group-hover:text-white transition-colors duration-300">
          View
          <svg 
            xmlns="http://www.w3.org/2000/svg" 
            class="h-3.5 w-3.5 transform group-hover:translate-x-0.5 transition-transform duration-300" 
            fill="none" 
            viewBox="0 0 24 24" 
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </span>
      </div>
    </div>
  </div>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
